def plural_fsm(word):
    # State 1: Check word ending
    if word.endswith(("s", "x", "z", "ch", "sh")):
        return word + "es"
    elif word.endswith("y") and word[-2] not in "aeiou":
        return word[:-1] + "ies"
    else:
        return word + "s"

# Input
noun = input("Enter a singular noun: ")

# Output
print("Plural form:", plural_fsm(noun))